{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SparkConnect",
  "version": "0.1.0",
  "identifier": "com.sparkconnect.io",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SparkConnect",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 650,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "dialog": null,
    "fs": null
  }
}